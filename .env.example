PORT=3010
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/alecooks?schema=public
BETTER_AUTH_SECRET=replace-me-with-a-32-plus-character-secret
BETTER_AUTH_URL=http://127.0.0.1:3010
ALECOOKS_OWNER_USERNAME=Ale
ALECOOKS_OWNER_DISPLAY_NAME=Ale
ALECOOKS_OWNER_EMAIL=ale@alecooks.local
ALECOOKS_OWNER_PASSWORD=replace-me-with-the-owner-password

# On Railway, BETTER_AUTH_URL can be omitted if the service has a Railway public domain.
# BETTER_AUTH_SECRET still must be set explicitly as a secret.
